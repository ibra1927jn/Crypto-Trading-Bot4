# =============================================
# Crypto-Trading-Bot4 — Environment Variables
# =============================================
# Copia este archivo como .env y rellena tus claves reales.
# NUNCA subas el .env a GitHub.

# Exchange a usar: binance, mexc, kucoin, bybit
EXCHANGE_ID=binance

# true = Testnet/Sandbox (paper trading), false = Dinero real
# CCXT activa sandbox mode automaticamente cuando es true.
# Testnet URLs por exchange:
#   Binance: https://testnet.binance.vision/
#   Bybit:   https://testnet.bybit.com/
#   KuCoin:  https://sandbox.kucoin.com/
#   MEXC:    No tiene testnet oficial — usar EXCHANGE_SANDBOX=true igual
TESTNET=true
EXCHANGE_SANDBOX=true

# API Keys — usar las del testnet si TESTNET=true
# Binance Testnet: https://testnet.binance.vision/ (genera keys ahi)
# Bybit Testnet: https://testnet.bybit.com/
# KuCoin Sandbox: https://sandbox.kucoin.com/
API_KEY=tu_api_key_aqui
API_SECRET=tu_api_secret_aqui

# Par y temporalidad
SYMBOL=BTC/USDT
SYMBOLS=XRP/USDT,DOGE/USDT,AVAX/USDT,SHIB/USDT,SOL/USDT
TIMEFRAME=5m

# Trading
ACTIVE_STRATEGY=ALLIN_RSI
TRADING_MODE=paper
CAPITAL=30

# Risk
DAILY_LOSS_LIMIT=10
MAX_DRAWDOWN_LIMIT=10
SLIPPAGE_MAX=0.5

# Deploy / SSH al servidor (scripts de deploy, check, diag)
DEPLOY_HOST=
DEPLOY_USER=root
DEPLOY_SSH_KEY=
DEPLOY_PASS=

# Telegram (scripts de monitoreo y reportes)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# News API
CRYPTOPANIC_TOKEN=

# Dashboard API Key (si vacio, auth deshabilitado — dev mode)
DASHBOARD_API_KEY=
