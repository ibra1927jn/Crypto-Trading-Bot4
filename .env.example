# ================================================
# CRYPTO TRADING BOT - CONFIGURACIÓN DE ENTORNO
# ================================================
# Copia este archivo como .env y completa con tus valores
# cp .env.example .env

# ================================================
# EXCHANGE CONFIGURATION
# ================================================
# API Keys de Binance
# Obtén tus keys en: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Usar Testnet (True) o Producción (False)
# IMPORTANTE: Siempre prueba primero en Testnet!
# Testnet Binance Futures: https://testnet.binancefuture.com/
USE_TESTNET=True

# ================================================
# TRADING CONFIGURATION
# ================================================
# Par de trading (BTC/USDT, ETH/USDT, etc.)
TRADING_SYMBOL=BTC/USDT

# Marco temporal (1m, 5m, 15m, 1h, 4h, 1d)
# Valores menores = más operaciones pero más ruido
# Valores mayores = menos operaciones pero más estables
TIMEFRAME=5m

# Tamaño de posición (porcentaje del balance)
# 0.01 = 1% del balance por operación
# Valores recomendados: 0.01 - 0.05
POSITION_SIZE=0.01

# Máximo número de posiciones abiertas simultáneamente
# Recomendado: 1-5 para gestión de riesgo
MAX_POSITIONS=3

# Stop Loss (porcentaje de pérdida máxima por operación)
# 2.0 = cerrar posición si pérdida alcanza 2%
STOP_LOSS=2.0

# Take Profit (porcentaje de ganancia objetivo)
# 4.0 = cerrar posición si ganancia alcanza 4%
TAKE_PROFIT=4.0

# ================================================
# STRATEGY CONFIGURATION
# ================================================
# Umbral de volatilidad para cambiar de estrategia
# Si volatilidad > umbral: SCALPING (indicadores)
# Si volatilidad <= umbral: SWING (con IA)
# Valores típicos: 1.5 - 3.0
VOLATILITY_THRESHOLD=2.0

# ================================================
# AI/ML CONFIGURATION
# ================================================
# Tipo de modelo: pytorch o tensorflow
AI_MODEL_TYPE=pytorch

# Ruta al archivo del modelo entrenado
# PyTorch: .pth o .pt
# TensorFlow: directorio del modelo
AI_MODEL_PATH=./models/trading_model.pth

# Usar GPU para inferencia (True/False)
# Requiere CUDA y PyTorch/TensorFlow con soporte GPU
USE_GPU=True

# ================================================
# LOGGING CONFIGURATION
# ================================================
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: Muestra toda la información (útil para desarrollo)
# INFO: Muestra información general (recomendado)
# WARNING: Solo advertencias y errores
LOG_LEVEL=INFO

# Archivo de logs
LOG_FILE=./logs/trading_bot.log
